# OpenTelemetry Configuration
# These environment variables configure the OTLP exporter

# OTLP endpoint (default: http://localhost:4318)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Optional: Custom headers for authentication (comma-separated key=value pairs)
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer TOKEN,X-Custom-Header=value

# Service name (used in traces)
OTEL_SERVICE_NAME=effect-app-example
